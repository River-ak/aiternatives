---
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  canonicalURL,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Impact.com 网站验证 -->
    <Fragment set:html={`<meta name="impact-site-verification" value="e2160d0-fcf8-4b81-b1de-fc6cae76e280">`} />

    <!-- Inter 字体（link 方式加载，避免 CSS @import 顺序问题） -->
    <link
      rel="preconnect"
      href="https://fonts.googleapis.com"
    />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />

    {canonicalURL && <link rel="canonical" href={canonicalURL} />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Pagefind 静态搜索 -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  </head>
  <body class="bg-[var(--bg-primary)] text-[var(--text-primary)] font-sans antialiased">
    <Header />
    <slot />
    <Footer />

    <!-- Pagefind 搜索弹窗 -->
    <div id="search-overlay" class="fixed inset-0 z-[100] bg-black/30 hidden transition-opacity duration-200" aria-hidden="true">
      <div class="absolute top-[15vh] left-1/2 -translate-x-1/2 w-full max-w-lg bg-white rounded-xl shadow-2xl overflow-hidden">
        <div class="flex items-center justify-between px-4 py-3 border-b" style="border-color: rgba(0,0,0,0.07);">
          <span class="text-[14px] font-medium text-[var(--text-secondary)]">Search AI Tool Alternatives</span>
          <button id="search-close" class="w-7 h-7 flex items-center justify-center rounded-md hover:bg-[var(--bg-hover)] transition-colors text-[var(--text-tertiary)]" aria-label="Close search">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <div id="search" class="pagefind-ui" data-pagefind-ui data-bundle-path="/pagefind/"></div>
      </div>
    </div>

    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        const searchBtn = document.querySelector('[aria-label="Search"]');
        const overlay = document.getElementById('search-overlay');
        const closeBtn = document.getElementById('search-close');
        const searchContainer = document.getElementById('search');

        if (searchBtn && overlay && closeBtn && searchContainer) {
          let instance = null;

          searchBtn.addEventListener('click', () => {
            overlay.classList.remove('hidden');
            overlay.setAttribute('aria-hidden', 'false');
            if (!instance) {
              instance = new PagefindUI({ element: '#search', showImages: false, showSubResults: true });
            }
            setTimeout(() => {
              const input = searchContainer.querySelector('input');
              if (input) input.focus();
            }, 100);
          });

          closeBtn.addEventListener('click', () => {
            overlay.classList.add('hidden');
            overlay.setAttribute('aria-hidden', 'true');
          });

          overlay.addEventListener('click', (e) => {
            if (e.target === overlay) {
              overlay.classList.add('hidden');
              overlay.setAttribute('aria-hidden', 'true');
            }
          });

          document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') {
              overlay.classList.add('hidden');
              overlay.setAttribute('aria-hidden', 'true');
            }
            if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
              e.preventDefault();
              searchBtn.click();
            }
          });
        }
      });
    </script>
  </body>
</html>
