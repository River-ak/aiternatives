---

<BaseLayout
  title="Jasper Alternatives — 9 Best AI Writing Tools Compared"
  description="Looking for Jasper alternatives? Compare pricing, features, and ratings across 9 AI writing tools including Copy.ai, Writesonic, Rytr, and more."
>
  <Breadcrumb
    items={[
      { label: 'Home', href: '/' },
      { label: 'Alternatives', href: '/alternatives/' },
      { label: 'Jasper Alternatives', href: '/alternatives/jasper/' },
    ]}
  />

  <article class="max-w-7xl mx-auto px-4 py-8">
    <header class="mb-10">
      <h1 class="text-[48px] font-semibold leading-[1.1] tracking-[-1.2px]">
        Jasper Alternatives
      </h1>
      <p class="mt-4 text-lg text-[var(--text-secondary)] max-w-2xl leading-relaxed">
        Jasper is a powerful AI writing tool, but the pricing may not fit every budget. Explore 9 alternatives with detailed comparisons on price, features, and user satisfaction.
      </p>
    </header>

    <!-- JSON-LD 结构化数据 -->
    <JsonLd
      type="product"
      products={alternatives.map((alt) => ({
        name: alt.name,
        description: alt.similarityReason || `Alternative to Jasper`,
        ratingValue: alt.userRating || 0,
        reviewCount: alt.ratingCount,
        ...(alt.minMonthlyPrice ? { price: String(alt.minMonthlyPrice) } : {}),
        url: `/go/${alt.slug}/`,
      }))}
    />

    <section class="mb-16">
      <h2 class="text-[28px] font-semibold leading-[1.2] tracking-[-0.56px] mb-8">
        Top Alternatives
      </h2>
      <ComparisonTable sourceToolName="Jasper" alternatives={alternatives} />
    </section>
  </article>
</BaseLayout>
