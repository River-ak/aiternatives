---
import '../../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonTable from '../../components/alternatives/ComparisonTable.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import type { AlternativeTool } from '../../components/alternatives/ComparisonTable.astro';


const alternatives: AlternativeTool[] = [
  {
    name: 'DALL-E 3',
    slug: 'dalle-3',
    pricingModel: 'usage_based',
    minMonthlyPrice: null,
    hasFreeTier: false,
    hasFreeTrial: false,
    features: ['Text-to-Image', 'Inpainting', 'ChatGPT Integration', 'High Resolution'],
    userRating: 4.5,
    ratingSource: 'G2',
    ratingCount: 3200,
    affiliateUrl: 'https://openai.com/dall-e-3',
    discountPercentage: null,
    similarityReason: 'Most direct competitor with ChatGPT integration',
  },
  {
    name: 'Stable Diffusion',
    slug: 'stable-diffusion',
    pricingModel: 'free',
