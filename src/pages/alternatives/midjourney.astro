    hasFreeTrial: false,
    features: ['Image Generation', 'Fine-tuning', 'Canvas Editor', 'Community Feed'],
    userRating: 4.7,
    ratingSource: 'G2',
    ratingCount: 4500,
    affiliateUrl: 'https://leonardo.ai',
    discountPercentage: 25,
    similarityReason: 'Best UI/UX with free daily credits',
  },
  {
    name: 'Adobe Firefly',
    slug: 'adobe-firefly',
    pricingModel: 'freemium',
    minMonthlyPrice: 4.99,
    hasFreeTier: true,
    hasFreeTrial: true,
    features: ['Generative Fill', 'Text Effects', 'Photoshop Integration', 'Commercial Safe'],
    userRating: 4.3,
    ratingSource: 'TrustPilot',
    ratingCount: 2100,
    affiliateUrl: 'https://firefly.adobe.com',
    discountPercentage: null,
    similarityReason: 'Commercial-safe images with Adobe ecosystem',
  },
  {
    name: 'Ideogram',
    slug: 'ideogram',
    pricingModel: 'freemium',
    minMonthlyPrice: 8,
    hasFreeTier: true,
    hasFreeTrial: false,
    features: ['Text Rendering', 'Image Generation', 'Remix', 'Describe'],
    userRating: 4.4,
    ratingSource: 'ProductHunt',
    ratingCount: 1800,
    affiliateUrl: 'https://ideogram.ai',
    discountPercentage: null,
    similarityReason: 'Best text-in-image rendering',
  },
  {
    name: 'Recraft',
    slug: 'recraft',
    pricingModel: 'freemium',
    minMonthlyPrice: 12,
    hasFreeTier: true,
    hasFreeTrial: false,
    features: ['Vector Graphics', 'Brand Kit', 'Style Control', 'Templates'],
    userRating: 4.5,
    ratingSource: 'G2',
    ratingCount: 960,
    affiliateUrl: 'https://recraft.ai',
    discountPercentage: 30,
    similarityReason: 'Vector + raster in one tool',
  },
  {
    name: 'Playground AI',
    slug: 'playground-ai',
    pricingModel: 'freemium',
    minMonthlyPrice: 12,
    hasFreeTier: true,
    hasFreeTrial: false,
    features: ['Canvas Editor', 'Image Generation', 'Mixed Media', 'Templates'],
    userRating: 4.2,
    ratingSource: 'G2',
    ratingCount: 1500,
    affiliateUrl: 'https://playground.com',
    discountPercentage: null,
    similarityReason: 'Canvas-first approach with editing tools',
  },
  {
    name: 'Runway ML',
    slug: 'runway-ml',
    pricingModel: 'subscription',
    minMonthlyPrice: 15,
    hasFreeTier: true,
    hasFreeTrial: true,
