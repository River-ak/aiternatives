---
import '../../styles/global.css';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ComparisonTable from '../../components/alternatives/ComparisonTable.astro';
import Breadcrumb from '../../components/seo/Breadcrumb.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { getAlternativesForSource } from '../../lib/supabase';
// 从 Supabase 拉取数据（构建时静态生成）
const alternatives = await getAlternativesForSource('midjourney');
const sourceToolName = 'Midjourney';

// 空状态测试用
const mockEmpty: typeof alternatives = [];


---

<BaseLayout
  title="Midjourney Alternatives — 8 Best AI Image Generators Compared"
  description="Compare the best Midjourney alternatives. Side-by-side pricing, features, and ratings for DALL-E 3, Stable Diffusion, Leonardo AI, and more."
>
  <Breadcrumb
    items={[
      { label: 'Home', href: '/' },
      { label: 'Alternatives', href: '/alternatives/' },
      { label: 'Midjourney Alternatives', href: '/alternatives/midjourney/' },
    ]}
  />

  <article class="max-w-7xl mx-auto px-4 py-8">
    <header class="mb-10">
      <h1 class="text-[48px] font-semibold leading-[1.1] tracking-[-1.2px]">
        Midjourney Alternatives
      </h1>
      <p class="mt-4 text-lg text-[var(--text-secondary)] max-w-2xl leading-relaxed">
        Midjourney is a leader in AI image generation, but it is not the only option. Compare 8 alternatives across pricing, features, and user ratings to find the one that fits your workflow.
      </p>
    </header>

    <!-- JSON-LD 结构化数据 -->
    <JsonLd
      type="product"
      products={alternatives.map((alt) => ({
        name: alt.name,
        description: alt.similarityReason || `Alternative to Midjourney`,
        ratingValue: alt.userRating || 0,
        reviewCount: alt.ratingCount,
        ...(alt.minMonthlyPrice ? { price: String(alt.minMonthlyPrice) } : {}),
        url: `/go/${alt.slug}/`,
      }))}
    />

    <section class="mb-16">
      <h2 class="text-[28px] font-semibold leading-[1.2] tracking-[-0.56px] mb-8">
        Top Alternatives
      </h2>
      <ComparisonTable sourceToolName={sourceToolName} alternatives={alternatives} />
    </section>
  </article>
</BaseLayout>
