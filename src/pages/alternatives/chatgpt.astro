---

<BaseLayout
  title="ChatGPT Alternatives — Compare AI Chat Tools"
  description="Structured comparison of ChatGPT alternatives: pricing, features, ratings, and more."
>
  <Breadcrumb
    items={[
      { label: 'Home', href: '/' },
      { label: 'Alternatives', href: '/alternatives/' },
      { label: 'ChatGPT Alternatives', href: '/alternatives/chatgpt/' },
    ]}
  />

  <article class="max-w-7xl mx-auto px-4 py-8">
    <!-- 页面标题 -->
    <header class="mb-10">
      <h1 class="text-[48px] font-semibold leading-[1.1] tracking-[-1.2px]">
        ChatGPT Alternatives
      </h1>
      <p class="mt-4 text-lg text-[var(--text-secondary)] max-w-2xl leading-relaxed">
        Compare the best ChatGPT alternatives side by side. Pricing, core features,
        user ratings, and more — all in one structured table.
      </p>
    </header>

    <!-- JSON-LD 结构化数据 -->
    <JsonLd
      type="product"
      products={mockAlternatives.map((alt) => ({
        name: alt.name,
        description: alt.similarityReason || `Alternative to ChatGPT`,
        ratingValue: alt.userRating || 0,
        reviewCount: alt.ratingCount,
        ...(alt.minMonthlyPrice ? { price: String(alt.minMonthlyPrice) } : {}),
        url: `/go/${alt.slug}/`,
      }))}
    />

    <!-- 核心对比表 —— 完整 12 个替代品 -->
    <section class="mb-16">
      <h2 class="text-[28px] font-semibold leading-[1.2] tracking-[-0.56px] mb-8">
        Top Alternatives
      </h2>
      <ComparisonTable
        sourceToolName="ChatGPT"
        alternatives={mockAlternatives}
      />
    </section>

    <!-- 空状态测试 —— 0 个替代品 -->
    <section>
      <h2 class="text-[28px] font-semibold leading-[1.2] tracking-[-0.56px] mb-8">
        Empty State Test
      </h2>
      <ComparisonTable
        sourceToolName="Unknown Tool"
        alternatives={mockEmpty}
      />
    </section>
  </article>
</BaseLayout>
