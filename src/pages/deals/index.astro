    discountPercentage: 50,
    dealUrl: 'https://albus.org',
    source: 'appsumo',
    expiresAt: '2026-07-18',
  },
  {
    toolName: 'Jasper',
    toolSlug: 'jasper',
    title: 'Creator plan — 25% off annual',
    originalPrice: 588,
    dealPrice: 441,
    discountPercentage: 25,
    couponCode: 'JASPER25',
    dealUrl: 'https://jasper.ai',
    source: 'twitter',
    expiresAt: '2026-07-22',
  },
  {
    toolName: 'Wordtune',
