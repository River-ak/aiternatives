import type { DealInfo } from '../../components/deals/DealCard.astro';

// 模拟折扣数据——实际场景从 Supabase 拉取
const deals: DealInfo[] = [
  {
    toolName: 'Rytr',
    toolSlug: 'rytr',
    title: 'Annual plan 40% off — unlimited AI writing',
    originalPrice: 29,
    dealPrice: 17.4,
    discountPercentage: 40,
    couponCode: 'RYTR40',
    dealUrl: 'https://rytr.me',
    source: 'official',
    expiresAt: '2026-07-31',
  },
  {
    toolName: 'Leonardo AI',
    toolSlug: 'leonardo-ai',
    title: 'Pro plan — 25% off first 3 months',
    originalPrice: 48,
    dealPrice: 36,
    discountPercentage: 25,
    dealUrl: 'https://leonardo.ai',
