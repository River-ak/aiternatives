---

<BaseLayout
  title="AI Tool Deals & Discounts — Save on AI Software Today"
  description="Find the latest discounts and deals on AI tools. Active coupons, promo codes, and limited-time offers from top AI SaaS products."
>
  <Breadcrumb
    items={[
      { label: 'Home', href: '/' },
      { label: 'Deals', href: '/deals/' },
    ]}
  />

  <main class="max-w-7xl mx-auto px-4 py-8">
    <header class="mb-10">
      <h1 class="text-[48px] font-semibold leading-[1.1] tracking-[-1.2px]">
        AI Tool Deals
      </h1>
      <p class="mt-4 text-lg text-[var(--text-secondary)] max-w-2xl leading-relaxed">
        Active discounts and promo codes for AI tools. Updated daily from official sources, AppSumo, Reddit, and Twitter.
      </p>
    </header>

    <!-- 折扣卡片网格 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {deals.map((deal) => (
        <DealCard deal={deal} />
      ))}
    </div>

    <!-- 空状态 -->
    {deals.length === 0 && (
      <div class="py-20 text-center text-[var(--text-tertiary)]">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mx-auto mb-4 text-[var(--text-disabled)]" aria-hidden="true">
          <path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/>
          <path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/>
          <path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/>
        </svg>
        <p class="text-[15px]">No active deals right now.</p>
        <p class="text-[13px] mt-1">Check back soon — new deals are added daily.</p>
      </div>
    )}

    <!-- 免责声明 -->
    <div class="mt-12 p-4 rounded-lg bg-[var(--bg-subtle)] text-[12px] text-[var(--text-tertiary)] leading-relaxed">
      <strong class="text-[var(--text-secondary)]">Affiliate Disclosure:</strong> Some deals on this page use affiliate links. If you make a purchase, we may earn a commission at no extra cost to you. Deals are checked daily but may expire without notice — always verify on the official site.
    </div>
  </main>
</BaseLayout>
