---
// =============================================================================
// DealCard.astro — 折扣卡片组件
// 用于 /deals/ 列表页
// =============================================================================

import DiscountBadge from './DiscountBadge.astro';

export interface DealInfo {
  toolName: string;
  toolSlug: string;
  title: string;
  originalPrice: number;
  dealPrice: number;
  discountPercentage: number;
  couponCode?: string;
  dealUrl: string;
  source: string;
  expiresAt: string;
}

export interface Props {
  deal: DealInfo;
}

const { deal } = Astro.props;

// 格式化价格
function fmtPrice(n: number): string {
  return n % 1 === 0 ? `$${n}` : `$${n.toFixed(2)}`;
}

// 计算剩余天数
function daysLeft(expires: string): string {
  const now = Date.now();
  const end = new Date(expires).getTime();
  const days = Math.ceil((end - now) / (1000 * 60 * 60 * 24));
  if (days <= 0) return 'Expired';
  if (days === 1) return 'Ends tomorrow';
  return `${days} days left`;
}

const saving = deal.originalPrice - deal.dealPrice;
---

<article
  class="group bg-white rounded-lg p-5 transition-all duration-200 hover:-translate-y-0.5"
  style="box-shadow: 0 0 0 1px rgba(0,0,0,0.07);"
>
  <div class="flex items-start justify-between mb-3">
    <!-- 工具名 + 折扣徽章 -->
    <div class="flex flex-col gap-1.5 min-w-0">
      <div class="flex items-center gap-2">
        <h3 class="text-[16px] font-semibold text-[var(--text-primary)] group-hover:text-[var(--accent)] transition-colors truncate">
          {deal.toolName}
        </h3>
        <DiscountBadge percentage={deal.discountPercentage} />
      </div>
      <p class="text-[14px] text-[var(--text-secondary)] truncate">{deal.title}</p>
    </div>

    <!-- 倒计时 -->
    <div class="flex-shrink-0 text-[12px] text-[var(--text-tertiary)] font-tnum ml-3">
      {daysLeft(deal.expiresAt)}
    </div>
  </div>

  <!-- 价格对比 -->
  <div class="flex items-baseline gap-2 mb-4 font-tnum">
    <span class="text-[24px] font-semibold text-[var(--text-primary)]">
      {fmtPrice(deal.dealPrice)}
    </span>
    <span class="text-[15px] text-[var(--text-tertiary)] line-through">
      {fmtPrice(deal.originalPrice)}
    </span>
    <span class="text-[13px] font-medium text-[var(--rating-high)]">
      Save {fmtPrice(saving)}
    </span>
  </div>

  <!-- 优惠码 + 来源 -->
  {deal.couponCode ? (
    <div class="flex items-center gap-2 mb-3 p-2 rounded-md bg-[var(--bg-subtle)]">
      <span class="text-[13px] font-medium text-[var(--text-secondary)]">Code:</span>
      <code class="text-[14px] font-semibold text-[var(--accent)] tracking-[0.05em]">{deal.couponCode}</code>
      <button
        class="ml-auto text-[12px] text-[var(--accent)] hover:underline font-medium"
        onclick={`navigator.clipboard.writeText('${deal.couponCode}')`}
      >
        Copy
      </button>
    </div>
  ) : null}

  <!-- 底部操作 -->
  <div class="flex items-center justify-between">
    <span class="text-[12px] text-[var(--text-tertiary)] capitalize">via {deal.source}</span>
    <a
      href={deal.dealUrl}
      rel="nofollow sponsored"
      class="visit-btn inline-flex items-center gap-1.5 px-4 py-2 rounded-md text-[14px] font-medium text-white transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]"
      style="background: var(--accent);"
    >
      Get Deal
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/>
        <path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
  </div>
</article>
