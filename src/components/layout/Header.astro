---
// =============================================================================
// Header.astro — 全局导航栏
// 风格：Vercel 的克制 + Stripe 的粘性毛玻璃
// =============================================================================

const navLinks = [
  { label: 'Alternatives', href: '/alternatives/' },
  { label: 'Categories', href: '#categories' },
  { label: 'Deals', href: '/deals/' },
];
---

<header
  class="sticky top-0 z-50 bg-white/80 backdrop-blur-[12px]"
  style="box-shadow: 0 0 0 1px rgba(0,0,0,0.06), 0 1px 4px rgba(0,0,0,0.04);"
>
  <nav
    class="max-w-7xl mx-auto px-4 h-12 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 flex-shrink-0" aria-label="aiternatives home">
      <svg width="24" height="24" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect width="32" height="32" rx="6" fill="#5c6cf0"/>
        <path d="M10 22h12M10 17h8M10 12h4" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span class="text-[15px] font-semibold tracking-[-0.3px] text-[var(--text-primary)]">
        aiternatives
      </span>
    </a>

    <!-- 导航链接 -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="px-3 py-1.5 text-[14px] font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] rounded-md transition-colors duration-150"
        >
          {link.label}
        </a>
      ))}
    </div>

    <!-- 搜索入口（桌面端） -->
    <div class="hidden md:flex items-center gap-3">
      <button
        class="flex items-center gap-2 px-3 py-1.5 text-[13px] text-[var(--text-tertiary)] bg-[var(--bg-subtle)] rounded-md border border-transparent hover:border-[rgba(0,0,0,0.08)] transition-all duration-150"
        aria-label="Search"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
        <span class="hidden lg:inline">Search tools...</span>
        <kbd class="hidden lg:inline text-[11px] px-1.5 py-0.5 rounded bg-white/50 border border-[rgba(0,0,0,0.06)] ml-1">/</kbd>
      </button>
    </div>

    <!-- 移动端菜单按钮 -->
    <button
      id="mobile-menu-btn"
      class="md:hidden flex items-center justify-center w-8 h-8 rounded-md hover:bg-[var(--bg-hover)] transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="3" y1="6" x2="21" y2="6"/>
        <line x1="3" y1="12" x2="21" y2="12"/>
        <line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </nav>

  <!-- 移动端下拉菜单 -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t"
    style="border-color: rgba(0,0,0,0.06);"
  >
    <div class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="px-3 py-2 text-[14px] font-medium text-[var(--text-secondary)] hover:text-[var(--text-primary)] hover:bg-[var(--bg-hover)] rounded-md transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>

  <!-- 移动端搜索 -->
  <div class="md:hidden px-4 pb-3">
    <div class="flex items-center gap-2 px-3 py-2 text-[13px] text-[var(--text-tertiary)] bg-[var(--bg-subtle)] rounded-md">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="8"/>
        <path d="m21 21-4.3-4.3"/>
      </svg>
      <span>Search tools...</span>
    </div>
  </div>
</header>

<script>
  // 移动端菜单切换（纯 JS，零依赖）
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (btn && menu) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      menu.classList.toggle('hidden');
    });
  }
</script>
