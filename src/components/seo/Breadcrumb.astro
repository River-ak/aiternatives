---
// =============================================================================
// Breadcrumb.astro — 面包屑导航（含 JSON-LD 结构化数据）
// =============================================================================

import JsonLd from './JsonLd.astro';

export interface Crumb {
  label: string;
  href: string;
}

export interface Props {
  items: Crumb[];
}

const { items } = Astro.props;

const breadcrumbLD = items.map((item) => ({
  name: item.label,
  url: new URL(item.href, Astro.site || 'https://aiternatives.com').toString(),
}));
---

<JsonLd type="breadcrumb" breadcrumb={breadcrumbLD} />

<nav aria-label="Breadcrumb" class="max-w-7xl mx-auto px-4 pt-6 pb-2">
  <ol class="flex items-center gap-1.5 text-[13px] text-[var(--text-tertiary)]">
    {items.map((item, i) => (
      <li class="flex items-center gap-1.5">
        {i > 0 && (
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        )}
        {i === items.length - 1 ? (
          <span class="text-[var(--text-secondary)] font-medium" aria-current="page">
            {item.label}
          </span>
        ) : (
          <a href={item.href} class="hover:text-[var(--text-primary)] transition-colors">
            {item.label}
          </a>
        )}
      </li>
    ))}
  </ol>
</nav>
